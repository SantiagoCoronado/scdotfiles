# Ghostty Configuration

# Theme
theme = Everforest Dark Hard

# Font configuration
font-family = JetBrainsMonoNL Nerd Font
font-family = JetBrainsMono Nerd Font
font-family = Hack Nerd Font
font-size = 19

# Window appearance
background-opacity = 0.75
background-blur-radius = 20
window-decoration = true
macos-titlebar-style = transparent

# Window padding
window-padding-x = 10
window-padding-y = 10

# Cursor
cursor-style = block
cursor-style-blink = true

# Shell integration
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# macOS specific
macos-option-as-alt = true

# Keybindings for word navigation (Option+Arrow)
keybind = alt+left=text:\x1bb
keybind = alt+right=text:\x1bf

# Additional useful keybindings
keybind = super+t=new_tab
keybind = super+w=close_surface
keybind = super+shift+left=previous_tab
keybind = super+shift+right=next_tab
keybind = super+enter=toggle_fullscreen

# Scrollback
scrollback-limit = 50000

# Copy/paste behavior
copy-on-select = clipboard
clipboard-paste-protection = true

# Mouse
mouse-hide-while-typing = true
