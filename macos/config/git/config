[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[user]
	name = Rodrigo Mourey
	email = 38763157+Mourey@users.noreply.github.com
[pull]
	rebase = false
[secrets]
	patterns = password
	patterns = PASSWORD
	patterns = secret
	patterns = SECRET
	patterns = api_key
	patterns = API_KEY
	patterns = private_key
	patterns = PRIVATE_KEY

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = Dracula

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
